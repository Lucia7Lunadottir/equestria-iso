[Appearance]
ColorScheme=PinkiePie
Font=Noto Mono,11,-1,5,50,0,0,0,0,0

[General]
Command=bash --rcfile ~/.local/share/konsole/PinkiePie.bashrc
Name=PinkiePie
Parent=FALLBACK/
TerminalColumns=120
TerminalRows=30

[Interaction Options]
AutoCopySelectedText=true

[Scrolling]
HistoryMode=2
ScrollBarPosition=2

[Terminal Features]
BlinkingCursorEnabled=true
